<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Texto blanco cuando el chip está seleccionado (fondo turquesa sólido) -->
    <item android:color="@android:color/white" android:state_checked="true"/>
    <!-- Texto turquesa oscuro/pastel cuando no está seleccionado (mejor contraste) -->
    <item android:color="@color/turquesa_oscuro"/>
</selector>