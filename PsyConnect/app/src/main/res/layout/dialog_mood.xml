<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Cómo te sientes hoy?"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#0F766E"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona el estado emocional que mejor te representa."
        android:layout_marginTop="8dp"
        android:textColor="#64748B"/>

    <Button
        android:id="@+id/btnExcellent"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="20dp"
        android:text="😊 Excelente"/>

    <Button
        android:id="@+id/btnGood"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:text="🙂 Bien"/>

    <Button
        android:id="@+id/btnNormal"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:text="😐 Normal"/>

    <Button
        android:id="@+id/btnSad"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:text="😔 Triste"/>

    <Button
        android:id="@+id/btnVeryBad"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:text="😣 Muy mal"/>

</LinearLayout>