<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_login">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/turquesa_oscuro"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:orientation="vertical">

        <!-- Contador de pregunta -->
        <TextView
            android:id="@+id/tvQuestionCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pregunta 1 de 4"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="10dp"/>

        <!-- Barra de progreso -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="25"
            android:progressDrawable="@drawable/progress_bar_drawable"
            android:background="@drawable/progress_bar_background"/>

    </LinearLayout>

    <!-- Tarjeta de pregunta -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/blanco">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_vertical">

            <!-- Ícono decorativo -->
            <TextView
                android:id="@+id/tvEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💭"
                android:textSize="40sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"/>

            <!-- Texto de la pregunta -->
            <TextView
                android:id="@+id/tvQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Cómo te has sentido hoy?"
                android:textColor="#1F2937"
                android:textSize="20sp"
                android:textStyle="bold"
                android:lineSpacingExtra="4dp"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>

            <!-- Opciones de respuesta -->
            <LinearLayout
                android:id="@+id/optionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Botón de siguiente/finalizar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Siguiente →"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/blanco"
            android:backgroundTint="@color/turquesa_principal"
            android:enabled="false"
            style="@style/Widget.Material3.Button"/>

    </LinearLayout>

</LinearLayout>