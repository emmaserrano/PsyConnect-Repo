<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recuperar contraseña"
        android:textSize="24sp"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/etEmailRecovery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Correo electrónico"/>

    <EditText
        android:id="@+id/etRecoveryCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Código recibido"
        android:inputType="number"/>

    <Button
        android:id="@+id/btnVerifyRecovery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Verificar código"/>

    <Button
        android:id="@+id/btnSendRecovery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enviar código"/>
</LinearLayout>