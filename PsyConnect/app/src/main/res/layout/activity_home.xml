<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- SALUDO -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hola 👋"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/turquesa_oscuro"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Cómo te sientes hoy?"
                android:textSize="18sp"
                android:textColor="@color/gris_texto"
                android:layout_marginBottom="24dp"/>


            <!-- CONSEJO -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:text="💡 Consejo"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:textColor="@color/turquesa_oscuro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Dedica unos minutos al día para respirar profundamente y desconectarte del estrés."
                        android:textSize="16sp"
                        android:layout_marginTop="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- FRASE -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:text="🌿 Frase motivacional"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:textColor="@color/turquesa_oscuro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text='"Cuidar tu salud mental también es una forma de quererte."'
                        android:textSize="16sp"
                        android:layout_marginTop="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- NUEVO TEST -->

            <androidx.cardview.widget.CardView
                android:id="@+id/cardTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#D8F6F2"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:orientation="vertical">

                    <TextView
                        android:text="🧠 Nuevo Test"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/turquesa_oscuro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Evalúa tu bienestar emocional mediante preguntas sencillas."
                        android:textSize="16sp"
                        android:layout_marginTop="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Comenzar →"
                        android:textStyle="bold"
                        android:textColor="@color/turquesa_oscuro"
                        android:textSize="18sp"
                        android:layout_marginTop="16dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- TITULO PSICOLOGOS -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👩‍⚕️ Especialistas recomendados"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/turquesa_oscuro"
                android:layout_marginBottom="12dp"/>


            <!-- RECYCLERVIEW -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPsychologists"
                android:layout_width="match_parent"
                android:layout_height="260dp"/>

        </LinearLayout>

    </ScrollView>


    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/windowBackground"
        app:itemIconTint="@color/bottom_nav_colors"
        app:itemTextColor="@color/bottom_nav_colors"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>